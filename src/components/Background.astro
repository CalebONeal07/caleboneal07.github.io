---
// Abstract UVA-themed background: navy + orange ambient glows, a heavily
// blurred Rotunda silhouette, and a faint colonnade base. All layers are
// low-opacity and sit behind page content for readability.
---

<div
    aria-hidden="true"
    class="pointer-events-none fixed inset-0 -z-10 overflow-hidden"
>
    <!-- Faint colonnade base (the Lawn's rhythm of columns) -->
    <div
        class="absolute inset-x-0 bottom-20 h-[40vh] opacity-[0.04] dark:opacity-[0.06]"
        style="
            background-image: repeating-linear-gradient(
                to right,
                var(--color-uva-navy) 0,
                var(--color-uva-navy) 10px,
                transparent 10px,
                transparent 64px
            );
            -webkit-mask-image: linear-gradient(to top, black, transparent);
            mask-image: linear-gradient(to top, black, transparent);
        "
    >
    </div>

    <!-- Abstract blurred Rotunda silhouette -->
