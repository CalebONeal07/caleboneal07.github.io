---
import Arrow from "../assets/arrow.svg";
---

<a
    href="#main"
    aria-label="Scroll to top"
    class="fixed bottom-6 right-6 z-20 inline-flex h-11 w-11 items-center justify-center rounded-full border border-neutral-300/80 bg-white/70 text-neutral-600 shadow-lg backdrop-blur transition-all duration-200 hover:-translate-y-0.5 hover:border-accent-400 hover:text-accent-600 dark:border-neutral-700/80 dark:bg-neutral-900/70 dark:text-neutral-300 dark:hover:border-accent-400 dark:hover:text-accent-300"
>
    <Arrow width={20} height={20} />
</a>
