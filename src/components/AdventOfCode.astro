---
import GitHub from "../assets/logos/github.svg";

interface Year {
    year: number;
    language: string;
    solved: number;
}

// Puzzles per day: 25 days (2015–2024), 12 days for 2025+.
const totalFor = (year: number) => (year <= 2024 ? 25 : 12);

const years: Year[] = [
    { year: 2015, language: "TypeScript", solved: 2 },
    { year: 2016, language: "Ruby", solved: 0 },
    { year: 2017, language: "Julia", solved: 0 },
    { year: 2018, language: "Swift", solved: 0 },
    { year: 2019, language: "Haskell", solved: 0 },
    { year: 2020, language: "C++", solved: 0 },
    { year: 2021, language: "Scala", solved: 0 },
    { year: 2022, language: "Rust", solved: 6 },
    { year: 2023, language: "Go", solved: 1 },
    { year: 2024, language: "Zig", solved: 0 },
    { year: 2025, language: "C", solved: 0 },
    { year: 2026, language: "Elixir", solved: 0 },
    { year: 2027, language: "OCaml", solved: 0 },
    { year: 2028, language: "Clojure", solved: 0 },
    { year: 2029, language: "Odin", solved: 0 },
    { year: 2030, language: "F#", solved: 0 },
    { year: 2031, language: "Idris", solved: 0 },
];

const totalSolved = years.reduce((acc, y) => acc + y.solved, 0);
const totalPuzzles = years.reduce((acc, y) => acc + totalFor(y.year), 0);
---

<article
    id="advent-of-code"
    class="group rounded-2xl border border-neutral-200 bg-white/70 p-6 shadow-sm backdrop-blur transition-all duration-200 hover:border-accent-300 hover:shadow-md dark:border-neutral-800 dark:bg-neutral-900/50 dark:hover:border-accent-500/50 sm:p-8"
>
    <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
            <h3 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100">
                Advent of Code
            </h3>
            <p class="mt-1 font-mono text-xs text-neutral-500 dark:text-neutral-500">
                {totalSolved} / {totalPuzzles} puzzles solved
            </p>
        </div>
        <a
            href="https://github.com/caleboneal07/advent-of-code"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Advent of Code repository on GitHub"
            class="inline-flex items-center gap-2 rounded-full border border-neutral-300/80 px-3 py-1.5 text-xs font-medium text-neutral-600 transition-colors hover:border-accent-400 hover:text-accent-600 dark:border-neutral-700/80 dark:text-neutral-400 dark:hover:border-accent-400 dark:hover:text-accent-300"
        >
            <GitHub width={16} height={16} />
            Repo
        </a>
    </div>

    <p class="mt-4 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
        <a
            class="font-medium text-accent-600 underline decoration-accent-300 underline-offset-2 transition-colors hover:decoration-accent-500 dark:text-accent-300"
            href="https://adventofcode.com/"
            target="_blank"
            rel="noopener noreferrer">Advent of Code</a
        > is an annual coding event held every December, with a new puzzle released
        each day. I take on each year in a different programming language as a way
        to keep learning new tools and paradigms.
    </p>

    <ul class="mt-6 space-y-2">
        {
            years.map(({ year, language, solved }) => {
                const total = totalFor(year);
                const pct = Math.round((solved / total) * 100);
                return (
                    <li class="grid grid-cols-[3.5rem_6.5rem_1fr_2.5rem] items-center gap-3 sm:grid-cols-[4rem_8rem_1fr_3rem]">
                        <span class="font-mono text-sm text-neutral-500 dark:text-neutral-500">
                            {year}
                        </span>
                        <span class="truncate text-sm font-medium text-neutral-700 dark:text-neutral-300">
                            {language}
                        </span>
                        <span class="h-2 overflow-hidden rounded-full bg-neutral-200 dark:bg-neutral-800">
                            <span
                                class="block h-full rounded-full bg-accent-500 transition-all duration-500 dark:bg-accent-400"
                                style={`width: ${pct}%`}
                            />
                        </span>
                        <span class="text-right font-mono text-xs text-neutral-400 dark:text-neutral-500">
                            {solved}/{total}
                        </span>
                    </li>
                );
            })
        }
    </ul>
</article>
