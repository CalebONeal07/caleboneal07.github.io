---
import "../styles/theme.css";
import Background from "../components/Background.astro";

interface Props {
    title?: string;
    description?: string;
}

const {
    title = "Caleb O'Neal | Portfolio",
    description = "Caleb O'Neal — B.S. Computer Engineering student at the University of Virginia. Portfolio and blog.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
            rel="stylesheet"
        />
    </head>
    <body
        class="relative min-h-screen bg-neutral-50 text-neutral-800 antialiased dark:bg-neutral-950 dark:text-neutral-200"
    >
        <Background />

        <slot />

        <footer
            class="mt-24 border-t border-neutral-200/70 py-8 dark:border-neutral-800/70"
        >
            <p
                class="text-center text-xs text-neutral-400 dark:text-neutral-600"
            >
                &copy; 2026 Caleb O'Neal · Built with Astro
            </p>
        </footer>
    </body>
</html>
